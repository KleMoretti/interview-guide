# ================================
# 必需配置 - 请替换为您的实际密钥
# ================================

# 阿里云百炼 AI (必需) - 在 https://dashscope.aliyun.com/ 获取
AI_BAILIAN_API_KEY=your_dashscope_api_key_here

# 阿里云语音服务 (必需) - 在 https://www.aliyun.com/product/nls 获取
#
# 支持两种认证方式（推荐使用 STS Token，更安全）：
#
# 方式1: STS Token（推荐）⭐
# - 临时访问凭证，有效期通常 1 小时
# - 更安全，符合最小权限原则
# - 在 RAM 控制台或使用 RAM 角色获取
# - 格式：cais...（以 cais 开头）或自定义格式
ALIYUN_ACCESS_KEY=your_sts_token_here
#
# 方式2: AccessKey ID（不推荐）
# - 长期密钥，永不过期（除非手动撤销）
# - 安全风险较高，不建议生产环境使用
# - 格式：LTAI5txxxxxxxxxxxxxxxxxxxxxxxx（以 LTAI5t 开头）
# ALIYUN_ACCESS_KEY=LTAI5txxxxxxxxxxxxxxxxxxxxxxxx
#
ALIYUN_STT_APP_KEY=your_stt_app_key_here
ALIYUN_TTS_APP_KEY=your_tts_app_key_here

# ================================
# 可选配置 - 已有默认值
# ================================

# 数据库配置 (默认: localhost:5432)
# 若使用 spring.profiles.active=dev + docker-compose-dev.yml，JDBC 端口固定为 15432（见 application-dev.yml），不受此处 POSTGRES_PORT 影响。
# dev  profile 使用 DEV_POSTGRES_PASSWORD（与 compose 中 POSTGRES_PASSWORD=password 一致）；勿依赖下方 POSTGRES_PASSWORD，以免与 compose 冲突。
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=interview_guide
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
# DEV_POSTGRES_PASSWORD=password

# Redis 配置 (默认: localhost:6379)
# dev profile + docker-compose-dev 时 Redisson 固定连 6380，不受此处 REDIS_PORT 影响。
REDIS_HOST=localhost
REDIS_PORT=6379

# 对象存储配置 (默认: MinIO)
APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=wr45VXJZhCxc6FAWz0YR
APP_STORAGE_SECRET_KEY=GtKxV57WJkpw4CvASPBzTy2DYElLnRqh8dIXQa0m
APP_STORAGE_BUCKET=interview-guide

# AI 模型配置 (默认: qwen-plus)
AI_MODEL=qwen-plus

# ================================
# 可选：其他 AI 服务提供商
# ================================

# MiniMax (如果使用 MiniMax 替代 DashScope)
# APP_VOICE_INTERVIEW_LLM_PROVIDER=minimax
# MINIMAX_API_KEY=your_minimax_api_key
# MINIMAX_GROUP_ID=your_minimax_group_id

# OpenAI (如果使用 OpenAI)
# APP_VOICE_INTERVIEW_LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key

# DeepSeek (如果使用 DeepSeek)
# APP_VOICE_INTERVIEW_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your_deepseek_api_key
